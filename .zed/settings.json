{
  "format_on_save": "on",
  "code_actions_on_format": { "source.fixAll.oxc": true },
  "formatter": {
    "external": {
      "command": "mise",
      "arguments": ["x", "--", "dprint", "fmt", "--stdin", "{buffer_path}"]
    }
  },
  "lsp": {
    "oxlint": {
      "initialization_options": {
        "settings": {
          "fixKind": "safe_fix",
          "typeAware": true,
          "unusedDisableDirectives": "deny"
        }
      }
    }
  }
}
